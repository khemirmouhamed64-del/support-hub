APP_NAME="Support Hub"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://support-hub.test
APP_LOCALE=en

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=support_hub
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DRIVER=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

# Gemini AI — clasificacion automatica de tickets
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Slack — notificaciones del equipo (opcional)
SLACK_WEBHOOK_URL=
